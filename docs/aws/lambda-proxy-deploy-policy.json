{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AllowCDKAndCloudFormation",
      "Effect": "Allow",
      "Action": [
        "cloudformation:*",
        "s3:*",
        "iam:PassRole",
        "iam:GetRole",
        "iam:CreateRole",
        "iam:DeleteRole",
        "iam:AttachRolePolicy",
        "iam:DetachRolePolicy",
        "iam:PutRolePolicy",
        "iam:DeleteRolePolicy",
        "iam:TagRole",
        "iam:UntagRole",
        "logs:*",
        "lambda:*",
        "ssm:GetParameter",
        "ssm:PutParameter",
        "sts:GetCallerIdentity"
      ],
      "Resource": "*"
    }
  ]
}
