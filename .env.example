# Root workspace
PNPM_HOME=

# WireGuard client and VPS settings
WG_INTERFACE=wg0
WG_SERVER_HOST=
WG_SERVER_PORT=51820
WG_ALLOWED_IPS=0.0.0.0/0,::/0
WG_CLIENT_DNS=1.1.1.1
WG_VPS_ENDPOINT_IP=

# Reserved for later packages
HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=localhost,127.0.0.1,::1,169.254.169.254
TLS_IMPERSONATION_PROFILE=chrome124

# Optional residential provider credentials for dynamic country targeting.
# Username format is provider-specific; this toolkit appends country-<iso2> when requested.
RES_PROXY_HOST=
RES_PROXY_PORT=80
RES_PROXY_USERNAME=
RES_PROXY_PASSWORD=
